# ── App ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-use-openssl-rand-hex-32
DATA_DIR=data
INVOICE_DIR=data/invoices
CERT_DIR=data/certs
DB_URL=sqlite:///data/app.db
# In the cloud use Postgres, e.g.:
# DB_URL=postgresql+psycopg2://user:password@host:5432/arcainvoices

# ── Authentication ────────────────────────────────────────────────────────────
# JWT secret for the session cookie (defaults to SECRET_KEY if blank).
JWT_SECRET=
# Cookie must be insecure over plain http (localhost); set true behind https.
COOKIE_SECURE=false
# Public base URL used in verification email links and OAuth redirects.
APP_BASE_URL=http://localhost:8000

# Seeded owner/admin account — bootstraps the first user (no self-registration).
# Existing local data is attached to this account on first run.
# CHANGE THE PASSWORD before deploying anywhere public.
ADMIN_EMAIL=admin@localhost
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ── Google OAuth (optional — enables "Sign in with Google") ───────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <OAUTH_REDIRECT_BASE>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:8000

# ── System SMTP (for account verification emails) ─────────────────────────────
# Distinct from the per-user notification SMTP configured in the app UI.
# If blank, verification links are only logged to the server console.
SYSTEM_SMTP_HOST=
SYSTEM_SMTP_PORT=587
SYSTEM_SMTP_USER=
SYSTEM_SMTP_PASSWORD=
SYSTEM_SMTP_FROM=

# ── CORS (add your frontend URL in production) ────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:4173"]

# ── AFIP/ARCA ─────────────────────────────────────────────────────────────────
AFIP_CUIT=
AFIP_CERT_PATH=data/certs/cert.crt
AFIP_KEY_PATH=data/certs/private.key
AFIP_PRODUCTION=false

# SiRADIG SOAP WSDL URLs — obtain from ManualSiRADIG.pdf v1.19:
# https://www.afip.gob.ar/572web/documentos/ManualSiRADIG.pdf
AFIP_SIRADIG_HOMO_WSDL=
AFIP_SIRADIG_PROD_WSDL=
AFIP_SIRADIG_SERVICE=siradig

AFIP_WSAA_HOMO_URL=https://wsaahomo.afip.gov.ar/ws/services/LoginCms
AFIP_WSAA_PROD_URL=https://wsaa.afip.gov.ar/ws/services/LoginCms

# ── Razón Social lookup (optional) ───────────────────────────────────────────
# Cuitalizer: simple REST API, 10 free credits/month (sufficient for personal use).
# Obtain your key at https://cuitalizer.com.ar
# If not set, falls back to ws_sr_padron_a13 (requires WSAA cert above).
CUITALIZER_API_KEY=

# ── Twilio (optional, for SMS notifications) ─────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
